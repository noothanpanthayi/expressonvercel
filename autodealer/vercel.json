{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/dist/index.html"
    }
  ]
}